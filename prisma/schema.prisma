// Cấu hình Prisma cho dự án Hải Sản Quê
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════
// Model Category - Danh mục sản phẩm
// Ví dụ: Mực khô, Cá khô, Tôm khô, Nước mắm, Combo
// ═══════════════════════════════════════════════════
model Category {
  id          String      @id @default(cuid())
  name        String      @map("name")
  slug        String      @unique @map("slug")
  description String?     @map("description")
  image       String?     @map("image")
  createdAt   DateTime    @default(now()) @map("created_at")

  // Quan hệ: Một danh mục có nhiều sản phẩm
  products Product[]

  @@map("categories")
}

// ═══════════════════════════════════════════════════
// Model Product - Sản phẩm hải sản
// Chứa thông tin chi tiết sản phẩm bao gồm giá, mô tả, tồn kho
// ═══════════════════════════════════════════════════
model Product {
  id             String      @id @default(cuid())
  name           String      @map("name")
  slug           String      @unique @map("slug")
  description    String?     @map("description")
  origin         String?     @map("origin")
  dryingProcess  String?     @map("drying_process")
  taste          String?     @map("taste")
  price          Int         @map("price")
  salePrice      Int?        @map("sale_price")
  stock          Int         @default(0) @map("stock")
  images         Json        @default("[]") @map("images")
  categoryId     String      @map("category_id")
  isFeatured     Boolean     @default(false) @map("is_featured")
  isBestSeller   Boolean     @default(false) @map("is_best_seller")
  isActive       Boolean     @default(true) @map("is_active")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  // Quan hệ
  category    Category    @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
  reviews     Review[]

  @@index([categoryId])
  @@index([isFeatured])
  @@index([isBestSeller])
  @@index([isActive])
  @@map("products")
}

// ═══════════════════════════════════════════════════
// Model Order - Đơn hàng
// Lưu thông tin khách hàng, tổng tiền, trạng thái đơn hàng
// ═══════════════════════════════════════════════════
enum PaymentMethod {
  COD           // Thanh toán khi nhận hàng
  BANK_TRANSFER // Chuyển khoản ngân hàng
}

enum OrderStatus {
  PENDING       // Chờ xác nhận
  CONFIRMED     // Đã xác nhận
  SHIPPING      // Đang giao hàng
  DELIVERED     // Đã giao hàng
  CANCELLED     // Đã hủy
}

model Order {
  id              String        @id @default(cuid())
  orderCode       String        @unique @map("order_code")
  customerName    String        @map("customer_name")
  phone           String        @map("phone")
  address         String        @map("address")
  province        String        @map("province")
  district        String        @map("district")
  ward            String        @map("ward")
  subtotal        Int           @default(0) @map("subtotal")
  totalAmount     Int           @map("total_amount")
  shippingFee     Int           @default(0) @map("shipping_fee")
  paymentMethod   PaymentMethod @default(COD) @map("payment_method")
  status          OrderStatus   @default(PENDING) @map("status")
  notes           String?       @map("notes")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  // Quan hệ: Một đơn hàng có nhiều sản phẩm
  items OrderItem[]

  @@index([orderCode])
  @@index([phone])
  @@index([status])
  @@map("orders")
}

// ═══════════════════════════════════════════════════
// Model OrderItem - Chi tiết đơn hàng
// Lưu thông tin sản phẩm trong từng đơn hàng
// ═══════════════════════════════════════════════════
model OrderItem {
  id        String  @id @default(cuid())
  orderId   String  @map("order_id")
  productId String  @map("product_id")
  quantity  Int     @map("quantity")
  price     Int     @map("price")

  // Quan hệ
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

// ═══════════════════════════════════════════════════
// Model Review - Đánh giá sản phẩm
// Khách hàng đánh giá sản phẩm từ 1-5 sao
// ═══════════════════════════════════════════════════
model Review {
  id           String   @id @default(cuid())
  productId    String   @map("product_id")
  customerName String   @map("customer_name")
  rating       Int      @map("rating")
  comment      String?  @map("comment")
  createdAt    DateTime @default(now()) @map("created_at")

  // Quan hệ
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("reviews")
}

// ═══════════════════════════════════════════════════
// Model Banner - Banner trang chủ
// Quản lý banner quảng cáo hiển thị trên trang chủ
// ═══════════════════════════════════════════════════
model Banner {
  id        String   @id @default(cuid())
  title     String   @map("title")
  subtitle  String?  @map("subtitle")
  image     String   @map("image")
  link      String?  @map("link")
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")

  @@map("banners")
}

// ═══════════════════════════════════════════════════
// Model BlogPost - Bài viết blog
// Chia sẻ công thức, mẹo chọn hải sản, câu chuyện thương hiệu
// ═══════════════════════════════════════════════════
model BlogPost {
  id          String   @id @default(cuid())
  title       String   @map("title")
  slug        String   @unique @map("slug")
  content     String   @map("content")
  image       String?  @map("image")
  excerpt     String?  @map("excerpt")
  isPublished Boolean  @default(false) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([isPublished])
  @@map("blog_posts")
}
